; SPIR-V
; Version: 1.5 (when assembled for Vulkan 1.2)
;
; Taskless MeshEXT fixture for specialization-constant output initializers.
; Vulkan permits constant instructions, including OpSpecConstant* results, as
; OpVariable initializers in the Output storage class.
               OpCapability MeshShadingEXT
               OpExtension "SPV_EXT_mesh_shader"
               OpMemoryModel Logical GLSL450
               OpEntryPoint MeshEXT %main "main" %indices %positions %weights %primitive_values
               OpExecutionMode %main LocalSize 1 1 1
               OpExecutionMode %main OutputPoints
               OpExecutionMode %main OutputVertices 2
               OpExecutionMode %main OutputPrimitivesEXT 2

               OpName %main "main"
               OpName %indices "gl_PrimitivePointIndicesEXT"
               OpName %positions "gl_Position"
               OpName %weights "weights"
               OpName %primitive_values "primitive_values"

               OpDecorate %indices BuiltIn PrimitivePointIndicesEXT
               OpDecorate %positions BuiltIn Position
               OpDecorate %weights Location 0
               OpDecorate %primitive_values Location 1
               OpDecorate %primitive_values PerPrimitiveEXT
               OpDecorate %spec_left SpecId 0
               OpDecorate %spec_right SpecId 1

       %void = OpTypeVoid
    %fn_void = OpTypeFunction %void
       %uint = OpTypeInt 32 0
      %float = OpTypeFloat 32
     %v2float = OpTypeVector %float 2
     %v4float = OpTypeVector %float 4

     %uint_0 = OpConstant %uint 0
     %uint_1 = OpConstant %uint 1
     %uint_2 = OpConstant %uint 2
   %float_n1 = OpConstant %float -1
    %float_0 = OpConstant %float 0
    %float_1 = OpConstant %float 1

  %spec_left = OpSpecConstant %float 0.25
 %spec_right = OpSpecConstant %float 0.75
  %spec_pair = OpSpecConstantComposite %v2float %spec_left %spec_right
%spec_pair_reversed = OpSpecConstantComposite %v2float %spec_right %spec_left

      %pos_0 = OpConstantComposite %v4float %float_n1 %float_0 %float_0 %float_1
      %pos_1 = OpConstantComposite %v4float %float_1 %float_0 %float_0 %float_1

%arr_uint_2 = OpTypeArray %uint %uint_2
%arr_v4float_2 = OpTypeArray %v4float %uint_2
%arr_float_2 = OpTypeArray %float %uint_2
%arr_v2float_2 = OpTypeArray %v2float %uint_2

       %weights_init = OpSpecConstantComposite %arr_float_2 %spec_left %spec_right
%primitive_values_init = OpSpecConstantComposite %arr_v2float_2 %spec_pair %spec_pair_reversed

%ptr_output_arr_uint_2 = OpTypePointer Output %arr_uint_2
%ptr_output_arr_v4float_2 = OpTypePointer Output %arr_v4float_2
%ptr_output_arr_float_2 = OpTypePointer Output %arr_float_2
%ptr_output_arr_v2float_2 = OpTypePointer Output %arr_v2float_2
%ptr_output_uint = OpTypePointer Output %uint
%ptr_output_v4float = OpTypePointer Output %v4float

            %indices = OpVariable %ptr_output_arr_uint_2 Output
          %positions = OpVariable %ptr_output_arr_v4float_2 Output
            %weights = OpVariable %ptr_output_arr_float_2 Output %weights_init
   %primitive_values = OpVariable %ptr_output_arr_v2float_2 Output %primitive_values_init

       %main = OpFunction %void None %fn_void
      %entry = OpLabel
               OpSetMeshOutputsEXT %uint_2 %uint_2
       %idx_0 = OpAccessChain %ptr_output_uint %indices %uint_0
               OpStore %idx_0 %uint_0
       %idx_1 = OpAccessChain %ptr_output_uint %indices %uint_1
               OpStore %idx_1 %uint_1
       %pos_0_ptr = OpAccessChain %ptr_output_v4float %positions %uint_0
               OpStore %pos_0_ptr %pos_0
       %pos_1_ptr = OpAccessChain %ptr_output_v4float %positions %uint_1
               OpStore %pos_1_ptr %pos_1
               OpReturn
               OpFunctionEnd
