#version 460
#extension GL_EXT_ray_tracing : require

hitAttributeEXT float hitData[2];

void update(inout float values[2])
{
    values[0] += values[1];
}

void main()
{
    hitData[1] = 1.0;
    update(hitData);
    float copy[2] = hitData;
    copy[0] += copy[1];
    hitData = copy;
    reportIntersectionEXT(hitData[0], uint(hitData[1]));
}
