#version 460
#extension GL_EXT_ray_tracing : require

layout(location = 0) callableDataInEXT vec4 incomingData[20];
layout(location = 1) callableDataEXT uint nestedData[2][3];

void main()
{
    incomingData[19].x += 1.0;
    nestedData[1][2] = uint(incomingData[19].x);
    executeCallableEXT(1, 1);
    incomingData[0].x += float(nestedData[0][0]);
}
