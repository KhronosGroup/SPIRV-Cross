#pragma clang diagnostic ignored "-Wmissing-prototypes"
#pragma clang diagnostic ignored "-Wmissing-braces"

#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

template<typename T, size_t Num>
struct spvUnsafeArray
{
    T elements[Num ? Num : 1];
    
    thread T& operator [] (size_t pos) thread
    {
        return elements[pos];
    }
    constexpr const thread T& operator [] (size_t pos) const thread
    {
        return elements[pos];
    }
    
    device T& operator [] (size_t pos) device
    {
        return elements[pos];
    }
    constexpr const device T& operator [] (size_t pos) const device
    {
        return elements[pos];
    }
    
    constexpr const constant T& operator [] (size_t pos) const constant
    {
        return elements[pos];
    }
    
    threadgroup T& operator [] (size_t pos) threadgroup
    {
        return elements[pos];
    }
    constexpr const threadgroup T& operator [] (size_t pos) const threadgroup
    {
        return elements[pos];
    }
    
    object_data T& operator [] (size_t pos) object_data
    {
        return elements[pos];
    }
    constexpr const object_data T& operator [] (size_t pos) const object_data
    {
        return elements[pos];
    }
};

void spvSetMeshOutputsEXT(uint gl_LocalInvocationIndex, device uint2& spvMeshSizes, uint vertexCount, uint primitiveCount)
{
    if (gl_LocalInvocationIndex == 0)
    {
        spvMeshSizes.x = vertexCount;
        spvMeshSizes.y = primitiveCount;
    }
}

struct gl_MeshPerVertexEXT
{
    float4 gl_Position [[position]];
};

constant uint3 gl_WorkGroupSize [[maybe_unused]] = uint3(1u);

struct spvPerVertex
{
    float4 gl_Position [[position]];
    uint4 signed_values_spv_i64_0 [[user(locn0)]];
    uint4 signed_values_spv_i64_2 [[user(locn1)]];
    uint4 unsigned_values_spv_i64_0 [[user(locn2)]];
    uint2 unsigned_values_spv_i64_2 [[user(locn3)]];
};

template<typename T>
struct alignas(8) spvMeshCapture64Lane
{
    uint2 data;
    
    device spvMeshCapture64Lane& operator=(T value) device
    {
        data = as_type<uint2>(value);
        return *this;
    }
    
    operator T() const device
    {
        return as_type<T>(data);
    }
    
    device spvMeshCapture64Lane& operator+=(T value) device
    {
        T current = *this;
        return *this = current + value;
    }
    
    device spvMeshCapture64Lane& operator-=(T value) device
    {
        T current = *this;
        return *this = current - value;
    }
    
    device spvMeshCapture64Lane& operator*=(T value) device
    {
        T current = *this;
        return *this = current * value;
    }
    
    device spvMeshCapture64Lane& operator/=(T value) device
    {
        T current = *this;
        return *this = current / value;
    }
    
    device spvMeshCapture64Lane& operator%=(T value) device
    {
        T current = *this;
        return *this = current % value;
    }
    
    device spvMeshCapture64Lane& operator&=(T value) device
    {
        T current = *this;
        return *this = current & value;
    }
    
    device spvMeshCapture64Lane& operator|=(T value) device
    {
        T current = *this;
        return *this = current | value;
    }
    
    device spvMeshCapture64Lane& operator^=(T value) device
    {
        T current = *this;
        return *this = current ^ value;
    }
    
    device spvMeshCapture64Lane& operator<<=(T value) device
    {
        T current = *this;
        return *this = current << value;
    }
    
    device spvMeshCapture64Lane& operator>>=(T value) device
    {
        T current = *this;
        return *this = current >> value;
    }
    
    device spvMeshCapture64Lane& operator++() device
    {
        T current = *this;
        *this = current + T(1);
        return *this;
    }
    
    T operator++(int) device
    {
        T current = *this;
        *this = current + T(1);
        return current;
    }
    
    device spvMeshCapture64Lane& operator--() device
    {
        T current = *this;
        *this = current - T(1);
        return *this;
    }
    
    T operator--(int) device
    {
        T current = *this;
        *this = current - T(1);
        return current;
    }
};

struct alignas(32) spvMeshCapture39_36
{
    spvMeshCapture64Lane<long> x;
    spvMeshCapture64Lane<long> y;
    spvMeshCapture64Lane<long> z;
    spvMeshCapture64Lane<long> w;
    
    device spvMeshCapture39_36& operator=(long4 value) device
    {
        x = value.x;
        y = value.y;
        z = value.z;
        w = value.w;
        return *this;
    }
    
    operator long4() const device
    {
        long4 value = {};
        value.x = x;
        value.y = y;
        value.z = z;
        value.w = w;
        return value;
    }
    
    device spvMeshCapture64Lane<long>& operator[](size_t pos) device
    {
        if (pos == 0) return x;
        if (pos == 1) return y;
        if (pos == 2) return z;
        return w;
    }
    
    const device spvMeshCapture64Lane<long>& operator[](size_t pos) const device
    {
        if (pos == 0) return x;
        if (pos == 1) return y;
        if (pos == 2) return z;
        return w;
    }
};

struct alignas(32) spvMeshCapture66_63
{
    spvMeshCapture64Lane<ulong> x;
    spvMeshCapture64Lane<ulong> y;
    spvMeshCapture64Lane<ulong> z;
    
    device spvMeshCapture66_63& operator=(ulong3 value) device
    {
        x = value.x;
        y = value.y;
        z = value.z;
        return *this;
    }
    
    operator ulong3() const device
    {
        ulong3 value = {};
        value.x = x;
        value.y = y;
        value.z = z;
        return value;
    }
    
    device spvMeshCapture64Lane<ulong>& operator[](size_t pos) device
    {
        if (pos == 0) return x;
        if (pos == 1) return y;
        return z;
    }
    
    const device spvMeshCapture64Lane<ulong>& operator[](size_t pos) const device
    {
        if (pos == 0) return x;
        if (pos == 1) return y;
        return z;
    }
};

struct spvMeshOutput
{
    uint2 counts;
    spvUnsafeArray<gl_MeshPerVertexEXT, 1> spv22;
    spvUnsafeArray<spvMeshCapture39_36, 1> spv39;
    spvUnsafeArray<spvMeshCapture66_63, 1> spv66;
    spvUnsafeArray<uint, 1> spv32;
};
static_assert(__builtin_offsetof(spvMeshOutput, counts) == 0, "invalid mesh output counts offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv22) == 16, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv39) == 32, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv66) == 64, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv32) == 96, "invalid mesh output variable offset");
static_assert(sizeof(spvMeshOutput) == 128, "invalid mesh output size");
static_assert(alignof(spvMeshOutput) == 32, "invalid mesh output alignment");

struct spvMeshDispatch
{
    uint4 grid;
};

using spvMesh_t = mesh<spvPerVertex, void, 1, 1, topology::point>;

static inline __attribute__((always_inline))
void _4(device spvUnsafeArray<gl_MeshPerVertexEXT, 1>& gl_MeshVerticesEXT, device spvUnsafeArray<uint, 1>& gl_PrimitivePointIndicesEXT, device spvUnsafeArray<spvMeshCapture39_36, 1>& signed_values, thread uint& gl_LocalInvocationIndex, device spvUnsafeArray<spvMeshCapture66_63, 1>& unsigned_values, device uint2& spvMeshSizes)
{
    spvSetMeshOutputsEXT(gl_LocalInvocationIndex, spvMeshSizes, 1u, 1u);
    gl_MeshVerticesEXT[0].gl_Position = float4(0.0, 0.0, 0.0, 1.0);
    gl_PrimitivePointIndicesEXT[0] = 0u;
    ((device long*)&signed_values[0])[gl_LocalInvocationIndex] = -1l;
    ((device long*)&signed_values[0])[1u] = 2l;
    ((device long*)&signed_values[0])[2u] = -3l;
    ((device long*)&signed_values[0])[3u] = 4l;
    ((device ulong*)&unsigned_values[0])[0u] = 6ul;
    ((device ulong*)&unsigned_values[0])[1u] = 7ul;
    ((device ulong*)&unsigned_values[0])[2u] = 8ul;
}

kernel void main0(device spvMeshOutput* spvMeshOutputs [[buffer(28)]], constant spvMeshDispatch& spvMeshDispatch [[buffer(29)]], uint3 spvMeshBatchWorkgroupID [[threadgroup_position_in_grid]], uint3 spvMeshBatchGrid [[threadgroups_per_grid]], uint3 spvMeshLocalInvocationID [[thread_position_in_threadgroup]], uint gl_LocalInvocationIndex [[thread_index_in_threadgroup]])
{
    const uint spvMeshOutputIndex = spvMeshBatchWorkgroupID.x + spvMeshBatchWorkgroupID.y * spvMeshBatchGrid.x + spvMeshBatchWorkgroupID.z * spvMeshBatchGrid.x * spvMeshBatchGrid.y;
    device spvMeshOutput& spvMeshOutput = spvMeshOutputs[spvMeshOutputIndex];
    device uint2& spvMeshSizes = spvMeshOutput.counts;
    if (gl_LocalInvocationIndex == 0) spvMeshSizes.y = 0u;
    device spvUnsafeArray<gl_MeshPerVertexEXT, 1> &gl_MeshVerticesEXT = spvMeshOutput.spv22;
    device spvUnsafeArray<uint, 1> &gl_PrimitivePointIndicesEXT = spvMeshOutput.spv32;
    device spvUnsafeArray<spvMeshCapture39_36, 1> &signed_values = spvMeshOutput.spv39;
    device spvUnsafeArray<spvMeshCapture66_63, 1> &unsigned_values = spvMeshOutput.spv66;
    _4(gl_MeshVerticesEXT, gl_PrimitivePointIndicesEXT, signed_values, gl_LocalInvocationIndex, unsigned_values, spvMeshSizes);
}


[[mesh]] void main0_replay(device const spvMeshOutput* spvMeshOutputs [[buffer(28)]], uint3 spvMeshReplayWorkgroupID [[threadgroup_position_in_grid]], uint3 spvMeshReplayGrid [[threadgroups_per_grid]], uint gl_LocalInvocationIndex [[thread_index_in_threadgroup]], spvMesh_t spvMesh)
{
    const uint spvMeshOutputIndex = spvMeshReplayWorkgroupID.x + spvMeshReplayWorkgroupID.y * spvMeshReplayGrid.x + spvMeshReplayWorkgroupID.z * spvMeshReplayGrid.x * spvMeshReplayGrid.y;
    const device spvMeshOutput& spvMeshOutput = spvMeshOutputs[spvMeshOutputIndex];
    const uint2 spvMeshSizes = uint2(spvMeshOutput.counts.x, spvMeshOutput.counts.y & 0x7fffffffu);
    const uint spvMeshProvokingVertexLast [[maybe_unused]] = spvMeshOutput.counts.y >> 31u;
    const device spvUnsafeArray<gl_MeshPerVertexEXT, 1> &gl_MeshVerticesEXT = spvMeshOutput.spv22;
    const device spvUnsafeArray<spvMeshCapture39_36, 1> &signed_values = spvMeshOutput.spv39;
    const device spvUnsafeArray<spvMeshCapture66_63, 1> &unsigned_values = spvMeshOutput.spv66;
    const device spvUnsafeArray<uint, 1> &gl_PrimitivePointIndicesEXT = spvMeshOutput.spv32;
    if (spvMeshSizes.y == 0)
    {
        return;
    }
    spvMesh.set_primitive_count(spvMeshSizes.y);
    const uint spvThreadCount [[maybe_unused]] = (gl_WorkGroupSize.x * gl_WorkGroupSize.y * gl_WorkGroupSize.z);
    const uint spvVI = gl_LocalInvocationIndex;
    if (gl_LocalInvocationIndex < spvMeshSizes.x)
    {
        spvPerVertex spvV = {};
        spvV.gl_Position = gl_MeshVerticesEXT[spvVI].gl_Position;
        spvV.signed_values_spv_i64_0 = uint4(spvMeshOutput.spv39[spvVI].x.data, spvMeshOutput.spv39[spvVI].y.data);
        spvV.signed_values_spv_i64_2 = uint4(spvMeshOutput.spv39[spvVI].z.data, spvMeshOutput.spv39[spvVI].w.data);
        spvV.unsigned_values_spv_i64_0 = uint4(spvMeshOutput.spv66[spvVI].x.data, spvMeshOutput.spv66[spvVI].y.data);
        spvV.unsigned_values_spv_i64_2 = spvMeshOutput.spv66[spvVI].z.data;
        spvMesh.set_vertex(spvVI, spvV);
    }
    const uint spvPI = gl_LocalInvocationIndex;
    if (gl_LocalInvocationIndex < spvMeshSizes.y)
    {
        spvMesh.set_index(spvPI, gl_PrimitivePointIndicesEXT[spvPI]);
    }
}
