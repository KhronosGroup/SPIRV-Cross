struct alignas(16) spvMeshCapture45_42
{
    spvMeshCapture64Lane<long> x;
    spvMeshCapture64Lane<long> y;
    
    device spvMeshCapture45_42& operator=(long2 value) device
    {
        x = value.x;
        y = value.y;
        return *this;
    }
    
    operator long2() const device
    {
        long2 value = {};
        value.x = x;
        value.y = y;
        return value;
    }
    
    device spvMeshCapture64Lane<long>& operator[](size_t pos) device
    {
        if (pos == 0) return x;
        return y;
    }
    
    const device spvMeshCapture64Lane<long>& operator[](size_t pos) const device
    {
        if (pos == 0) return x;
        return y;
    }
};

