struct spvMeshOutput
{
    uint2 counts;
    spvUnsafeArray<gl_MeshPerVertexEXT, 1> spv14;
    spvUnsafeArray<spvMeshCapture64Lane<long>, 1> spv31;
    spvUnsafeArray<spvMeshCapture64Lane<ulong>, 1> spv38;
    spvUnsafeArray<spvMeshCapture45_42, 1> spv45;
    spvUnsafeArray<spvMeshCapture54_51, 1> spv54;
    spvUnsafeArray<uint, 1> spv24;
    spvUnsafeArray<spvMeshCapture64_61, 1> spv64;
};
static_assert(__builtin_offsetof(spvMeshOutput, counts) == 0, "invalid mesh output counts offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv14) == 16, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv31) == 32, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv38) == 40, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv45) == 48, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv54) == 64, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv24) == 96, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv64) == 128, "invalid mesh output variable offset");
static_assert(sizeof(spvMeshOutput) == 160, "invalid mesh output size");
static_assert(alignof(spvMeshOutput) == 32, "invalid mesh output alignment");

struct spvMeshDispatch
{
    uint4 grid;
};

using spvMesh_t = mesh<spvPerVertex, spvPerPrimitive, 1, 1, topology::point>;

static inline __attribute__((always_inline))
void _4(device spvUnsafeArray<gl_MeshPerVertexEXT, 1>& gl_MeshVerticesEXT, device spvUnsafeArray<uint, 1>& gl_PrimitivePointIndicesEXT, device spvUnsafeArray<spvMeshCapture64Lane<long>, 1>& scalar_i64, device spvUnsafeArray<spvMeshCapture64Lane<ulong>, 1>& scalar_u64, device spvUnsafeArray<spvMeshCapture45_42, 1>& vector_i64_2, device spvUnsafeArray<spvMeshCapture54_51, 1>& vector_u64_3, device spvUnsafeArray<spvMeshCapture64_61, 1>& primitive_i64_4, thread uint& gl_LocalInvocationIndex, device uint2& spvMeshSizes)
{
    spvSetMeshOutputsEXT(gl_LocalInvocationIndex, spvMeshSizes, 1u, 1u);
    gl_MeshVerticesEXT[0].gl_Position = float4(0.0, 0.0, 0.0, 1.0);
    gl_PrimitivePointIndicesEXT[0] = 0u;
    scalar_i64[0] = -1l;
    scalar_u64[0] = 2ul;
    vector_i64_2[0] = long2(-3l, 4l);
    vector_u64_3[0] = ulong3(5ul, 6ul, 7ul);
    primitive_i64_4[0] = long4(-8l, 9l, -10l, 11l);
}

kernel void main0(device spvMeshOutput* spvMeshOutputs [[buffer(28)]], constant spvMeshDispatch& spvMeshDispatch [[buffer(29)]], uint3 spvMeshBatchWorkgroupID [[threadgroup_position_in_grid]], uint3 spvMeshBatchGrid [[threadgroups_per_grid]], uint3 spvMeshLocalInvocationID [[thread_position_in_threadgroup]], uint gl_LocalInvocationIndex [[thread_index_in_threadgroup]])
{
    const uint spvMeshOutputIndex = spvMeshBatchWorkgroupID.x + spvMeshBatchWorkgroupID.y * spvMeshBatchGrid.x + spvMeshBatchWorkgroupID.z * spvMeshBatchGrid.x * spvMeshBatchGrid.y;
    device spvMeshOutput& spvMeshOutput = spvMeshOutputs[spvMeshOutputIndex];
    device uint2& spvMeshSizes = spvMeshOutput.counts;
    if (gl_LocalInvocationIndex == 0) spvMeshSizes.y = 0u;
    device spvUnsafeArray<gl_MeshPerVertexEXT, 1> &gl_MeshVerticesEXT = spvMeshOutput.spv14;
    device spvUnsafeArray<uint, 1> &gl_PrimitivePointIndicesEXT = spvMeshOutput.spv24;
    device spvUnsafeArray<spvMeshCapture64Lane<long>, 1> &scalar_i64 = spvMeshOutput.spv31;
    device spvUnsafeArray<spvMeshCapture64Lane<ulong>, 1> &scalar_u64 = spvMeshOutput.spv38;
    device spvUnsafeArray<spvMeshCapture45_42, 1> &vector_i64_2 = spvMeshOutput.spv45;
    device spvUnsafeArray<spvMeshCapture54_51, 1> &vector_u64_3 = spvMeshOutput.spv54;
    device spvUnsafeArray<spvMeshCapture64_61, 1> &primitive_i64_4 = spvMeshOutput.spv64;
    _4(gl_MeshVerticesEXT, gl_PrimitivePointIndicesEXT, scalar_i64, scalar_u64, vector_i64_2, vector_u64_3, primitive_i64_4, gl_LocalInvocationIndex, spvMeshSizes);
}


[[mesh]] void main0_replay(device const spvMeshOutput* spvMeshOutputs [[buffer(28)]], uint3 spvMeshReplayWorkgroupID [[threadgroup_position_in_grid]], uint3 spvMeshReplayGrid [[threadgroups_per_grid]], uint gl_LocalInvocationIndex [[thread_index_in_threadgroup]], spvMesh_t spvMesh)
{
    const uint spvMeshOutputIndex = spvMeshReplayWorkgroupID.x + spvMeshReplayWorkgroupID.y * spvMeshReplayGrid.x + spvMeshReplayWorkgroupID.z * spvMeshReplayGrid.x * spvMeshReplayGrid.y;
    const device spvMeshOutput& spvMeshOutput = spvMeshOutputs[spvMeshOutputIndex];
    const uint2 spvMeshSizes = uint2(spvMeshOutput.counts.x, spvMeshOutput.counts.y & 0x7fffffffu);
    const uint spvMeshProvokingVertexLast [[maybe_unused]] = spvMeshOutput.counts.y >> 31u;
    const device spvUnsafeArray<gl_MeshPerVertexEXT, 1> &gl_MeshVerticesEXT = spvMeshOutput.spv14;
    const device spvUnsafeArray<spvMeshCapture64Lane<long>, 1> &scalar_i64 = spvMeshOutput.spv31;
    const device spvUnsafeArray<spvMeshCapture64Lane<ulong>, 1> &scalar_u64 = spvMeshOutput.spv38;
    const device spvUnsafeArray<spvMeshCapture45_42, 1> &vector_i64_2 = spvMeshOutput.spv45;
    const device spvUnsafeArray<spvMeshCapture54_51, 1> &vector_u64_3 = spvMeshOutput.spv54;
    const device spvUnsafeArray<uint, 1> &gl_PrimitivePointIndicesEXT = spvMeshOutput.spv24;
    const device spvUnsafeArray<spvMeshCapture64_61, 1> &primitive_i64_4 = spvMeshOutput.spv64;
    if (spvMeshSizes.y == 0)
    {
        return;
    }
    spvMesh.set_primitive_count(spvMeshSizes.y);
    const uint spvThreadCount [[maybe_unused]] = (gl_WorkGroupSize.x * gl_WorkGroupSize.y * gl_WorkGroupSize.z);
    const uint spvVI = gl_LocalInvocationIndex;
    if (gl_LocalInvocationIndex < spvMeshSizes.x)
    {
        spvPerVertex spvV = {};
        spvV.gl_Position = gl_MeshVerticesEXT[spvVI].gl_Position;
        spvV.scalar_i64_spv_i64_0 = spvMeshOutput.spv31[spvVI].data;
        spvV.scalar_u64_spv_i64_0 = spvMeshOutput.spv38[spvVI].data;
        spvV.vector_i64_2_spv_i64_0 = uint4(spvMeshOutput.spv45[spvVI].x.data, spvMeshOutput.spv45[spvVI].y.data);
        spvV.vector_u64_3_spv_i64_0 = uint4(spvMeshOutput.spv54[spvVI].x.data, spvMeshOutput.spv54[spvVI].y.data);
        spvV.vector_u64_3_spv_i64_2 = spvMeshOutput.spv54[spvVI].z.data;
        spvMesh.set_vertex(spvVI, spvV);
    }
    const uint spvPI = gl_LocalInvocationIndex;
    if (gl_LocalInvocationIndex < spvMeshSizes.y)
    {
        spvMesh.set_index(spvPI, gl_PrimitivePointIndicesEXT[spvPI]);
        spvPerPrimitive spvP = {};
        spvP.primitive_i64_4_spv_i64_0 = uint4(spvMeshOutput.spv64[spvPI].x.data, spvMeshOutput.spv64[spvPI].y.data);
        spvP.primitive_i64_4_spv_i64_2 = uint4(spvMeshOutput.spv64[spvPI].z.data, spvMeshOutput.spv64[spvPI].w.data);
        spvMesh.set_primitive(spvPI, spvP);
    }
}
