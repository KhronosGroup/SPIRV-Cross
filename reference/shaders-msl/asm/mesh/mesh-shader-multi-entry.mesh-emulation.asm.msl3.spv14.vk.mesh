#pragma clang diagnostic ignored "-Wmissing-prototypes"
#pragma clang diagnostic ignored "-Wmissing-braces"

#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

template<typename T, size_t Num>
struct spvUnsafeArray
{
    T elements[Num ? Num : 1];
    
    thread T& operator [] (size_t pos) thread
    {
        return elements[pos];
    }
    constexpr const thread T& operator [] (size_t pos) const thread
    {
        return elements[pos];
    }
    
    device T& operator [] (size_t pos) device
    {
        return elements[pos];
    }
    constexpr const device T& operator [] (size_t pos) const device
    {
        return elements[pos];
    }
    
    constexpr const constant T& operator [] (size_t pos) const constant
    {
        return elements[pos];
    }
    
    threadgroup T& operator [] (size_t pos) threadgroup
    {
        return elements[pos];
    }
    constexpr const threadgroup T& operator [] (size_t pos) const threadgroup
    {
        return elements[pos];
    }
    
    object_data T& operator [] (size_t pos) object_data
    {
        return elements[pos];
    }
    constexpr const object_data T& operator [] (size_t pos) const object_data
    {
        return elements[pos];
    }
};

void spvSetMeshOutputsEXT(uint gl_LocalInvocationIndex, device uint2& spvMeshSizes, uint vertexCount, uint primitiveCount)
{
    if (gl_LocalInvocationIndex == 0)
    {
        spvMeshSizes.x = vertexCount;
        spvMeshSizes.y = primitiveCount;
    }
}

constant uint _10_tmp [[function_constant(7)]];
constant uint _10 = is_function_constant_defined(_10_tmp) ? _10_tmp : 8u;
constant uint3 gl_WorkGroupSize [[maybe_unused]] = uint3(_10, 1u, 1u);

struct _37
{
    uint _m0;
};

struct spvPerVertex
{
    float4 gl_Position [[position]];
    float4 color [[user(locn0)]];
};

struct spvMeshOutput
{
    uint2 counts;
    spvUnsafeArray<float4, 3> spv3;
    spvUnsafeArray<float4, 3> spv4;
    spvUnsafeArray<uint3, 1> spv2;
};
static_assert(__builtin_offsetof(spvMeshOutput, counts) == 0, "invalid mesh output counts offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv3) == 16, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv4) == 64, "invalid mesh output variable offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv2) == 112, "invalid mesh output variable offset");
static_assert(sizeof(spvMeshOutput) == 128, "invalid mesh output size");
static_assert(alignof(spvMeshOutput) == 16, "invalid mesh output alignment");

struct spvMeshDispatch
{
    uint4 grid;
};

using spvMesh_t = mesh<spvPerVertex, void, 3, 1, topology::triangle>;

static inline __attribute__((always_inline))
void _1(device spvUnsafeArray<uint3, 1>& gl_PrimitiveTriangleIndicesEXT, device spvUnsafeArray<float4, 3>& gl_Position, device spvUnsafeArray<float4, 3>& color, thread uint& gl_LocalInvocationIndex, device uint2& spvMeshSizes)
{
    spvSetMeshOutputsEXT(gl_LocalInvocationIndex, spvMeshSizes, 3u, 1u);
    gl_PrimitiveTriangleIndicesEXT[0u] = uint3(0u, 1u, 2u);
    gl_Position[0u] = float4(0.0, 0.0, 0.0, 1.0);
    color[0u] = float4(1.0, 0.0, 0.0, 1.0);
    threadgroup_barrier(mem_flags::mem_device);
}

kernel void main0(device spvMeshOutput* spvMeshOutputs [[buffer(28)]], constant spvMeshDispatch& spvMeshDispatch [[buffer(29)]], uint3 spvMeshBatchWorkgroupID [[threadgroup_position_in_grid]], uint3 spvMeshBatchGrid [[threadgroups_per_grid]], uint3 spvMeshLocalInvocationID [[thread_position_in_threadgroup]], uint gl_LocalInvocationIndex [[thread_index_in_threadgroup]])
{
    const uint spvMeshOutputIndex = spvMeshBatchWorkgroupID.x + spvMeshBatchWorkgroupID.y * spvMeshBatchGrid.x + spvMeshBatchWorkgroupID.z * spvMeshBatchGrid.x * spvMeshBatchGrid.y;
    device spvMeshOutput& spvMeshOutput = spvMeshOutputs[spvMeshOutputIndex];
    device uint2& spvMeshSizes = spvMeshOutput.counts;
    if (gl_LocalInvocationIndex == 0) spvMeshSizes.y = 0u;
    device spvUnsafeArray<uint3, 1> &gl_PrimitiveTriangleIndicesEXT = spvMeshOutput.spv2;
    device spvUnsafeArray<float4, 3> &gl_Position = spvMeshOutput.spv3;
    device spvUnsafeArray<float4, 3> &color = spvMeshOutput.spv4;
    _1(gl_PrimitiveTriangleIndicesEXT, gl_Position, color, gl_LocalInvocationIndex, spvMeshSizes);
}


[[mesh]] void main0_replay(device const spvMeshOutput* spvMeshOutputs [[buffer(28)]], uint3 spvMeshReplayWorkgroupID [[threadgroup_position_in_grid]], uint3 spvMeshReplayGrid [[threadgroups_per_grid]], uint gl_LocalInvocationIndex [[thread_index_in_threadgroup]], spvMesh_t spvMesh)
{
    const uint spvMeshOutputIndex = spvMeshReplayWorkgroupID.x + spvMeshReplayWorkgroupID.y * spvMeshReplayGrid.x + spvMeshReplayWorkgroupID.z * spvMeshReplayGrid.x * spvMeshReplayGrid.y;
    const device spvMeshOutput& spvMeshOutput = spvMeshOutputs[spvMeshOutputIndex];
    const uint2 spvMeshSizes = uint2(spvMeshOutput.counts.x, spvMeshOutput.counts.y & 0x7fffffffu);
    const uint spvMeshProvokingVertexLast [[maybe_unused]] = spvMeshOutput.counts.y >> 31u;
    const device spvUnsafeArray<float4, 3> &gl_Position = spvMeshOutput.spv3;
    const device spvUnsafeArray<float4, 3> &color = spvMeshOutput.spv4;
    const device spvUnsafeArray<uint3, 1> &gl_PrimitiveTriangleIndicesEXT = spvMeshOutput.spv2;
    if (spvMeshSizes.y == 0)
    {
        return;
    }
    spvMesh.set_primitive_count(spvMeshSizes.y);
    const uint spvThreadCount [[maybe_unused]] = (gl_WorkGroupSize.x * gl_WorkGroupSize.y * gl_WorkGroupSize.z);
    for (uint spvVI = gl_LocalInvocationIndex; spvVI < spvMeshSizes.x; spvVI += spvThreadCount)
    {
        spvPerVertex spvV = {};
        spvV.gl_Position = gl_Position[spvVI];
        spvV.color = color[spvVI];
        spvMesh.set_vertex(spvVI, spvV);
    }
    for (uint spvPI = gl_LocalInvocationIndex; spvPI < spvMeshSizes.y; spvPI += spvThreadCount)
    {
        spvMesh.set_index(spvPI * 3u + 0u, gl_PrimitiveTriangleIndicesEXT[spvPI].x);
        spvMesh.set_index(spvPI * 3u + 1u, gl_PrimitiveTriangleIndicesEXT[spvPI].y);
        spvMesh.set_index(spvPI * 3u + 2u, gl_PrimitiveTriangleIndicesEXT[spvPI].z);
    }
}
