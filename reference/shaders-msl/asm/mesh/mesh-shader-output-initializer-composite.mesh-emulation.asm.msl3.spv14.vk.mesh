struct spvMeshOutput
{
    uint2 counts;
    spvUnsafeArray<float4, 3> spv4;
    spvUnsafeArray<VertexPayload, 3> spv6;
    spvUnsafeArray<float2x2, 3> spv7;
    spvUnsafeArray<uint3, 1> spv3;
    spvUnsafeArray<bool, 1> spv5;
    spvUnsafeArray<PrimitivePayload, 1> spv8;
};
static_assert(__builtin_offsetof(spvMeshOutput, counts) == 0, "invalid mesh output counts offset");
static_assert(__builtin_offsetof(spvMeshOutput, spv4) == 16, "invalid mesh output variable offset");
