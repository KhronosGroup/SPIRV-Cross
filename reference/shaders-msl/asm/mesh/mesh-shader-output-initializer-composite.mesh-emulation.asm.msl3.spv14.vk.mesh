        spvV.gl_Position = _RESERVED_IDENTIFIER_FIXUP_gl_Position[spvVI];
        spvV.vertex_payload_color = vertex_payload[spvVI].color;
        spvV.vertex_payload_uv_pair_0 = vertex_payload[spvVI].uv_pair[0];
